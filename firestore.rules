rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /cards/{cardId} {
      allow get: if true;
      allow create: if cardId is string 
        && cardId.size() <= 128
        && request.resource.data.recipientName != null
        && request.resource.data.recipientName is string;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['passcodeBgUrl', 'passcodeTextColor']);
      allow delete: if false;
    }
  }
}
