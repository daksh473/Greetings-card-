rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /cards/{cardId} {
      allow get: if true;
      allow create: if cardId is string 
        && cardId.size() <= 128
        && request.resource.data.recipientName != null
        && request.resource.data.recipientName is string;
      allow update, delete: if false; // Cards are immutable once shared
    }
  }
}
